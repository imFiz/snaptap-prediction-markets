# ── TxLINE (TxODDS) data layer ───────────────────────────────────────────────
# Server-side only: the API token is proxied by the backend, never shipped to
# the browser. Obtain via the TxLINE guest/subscription flow.
TXODDS_API_TOKEN="txoracle_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Devnet API base. Use https://txline.txodds.com for mainnet/production.
TXLINE_API_BASE="https://txline-dev.txodds.com"

# ── Solana / on-chain settlement ─────────────────────────────────────────────
SOLANA_CLUSTER="devnet"
SOLANA_RPC_URL="https://api.devnet.solana.com"
# Filled in after `anchor deploy` (see README).
VITE_SNAPTAP_PROGRAM_ID="Snap1111111111111111111111111111111111111111"
# Demo USDC SPL mint used for staking on devnet.
VITE_STAKE_MINT=""
# TxLINE devnet program (CPI target for resolution).
VITE_TXLINE_PROGRAM_ID="6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J"

# ── Auth (Solana wallet signature) ───────────────────────────────────────────
# Random secret used to sign session tokens issued after wallet sign-in.
SESSION_SECRET="change-me-to-a-long-random-string"

# ── Misc ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:4005"
# Optional: Gemini key for any AI-assisted copy (not required for core flow).
GEMINI_API_KEY=""
